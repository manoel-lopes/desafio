# Copy to .env at repo root: cp .env.example .env
# Used by docker-compose (api + infra). Do not commit .env.

# API (Nest) — port inside container and on host
NODE_ENV=development
PORT=3333

# Frontend (Angular SSR) — port inside container and on host
FRONT_PORT=4000

# Database (must match postgres service credentials)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=template_api
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/template_api?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Optional: restrict CORS when calling the API directly (browser → API).
# UI uses same-origin /api via the front container; set if you expose the API to other origins.
# ALLOWED_ORIGINS=http://localhost:4000
