# Application
NODE_ENV=development
PORT=3333

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=template_api
# Prisma CLI (migrate, studio) uses DATABASE_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/template_api?schema=public
# Or use DATABASE_URL directly (overrides individual DB_* vars in app — keep in sync with DB_*)

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Docker — backend-only compose (back/docker-compose.yml): set hosts to service names
# DB_HOST=postgres
# REDIS_HOST=redis
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/template_api?schema=public
#
# Full stack (front + api + db + redis): use repo root — copy ../.env.example to ../.env
# and run `docker compose up -d --build` from the repository root.
