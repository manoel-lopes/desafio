model Notification {
    id          String    @id @default(uuid(7))
    recipientId String    @map("recipient_id")
    title       String
    content     String
    readAt      DateTime? @map("read_at")
    createdAt   DateTime  @default(now()) @map("created_at")

    recipient User @relation(fields: [recipientId], references: [id])

    @@map("notifications")
}
