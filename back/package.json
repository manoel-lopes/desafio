{
  "name": "back",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build && rm -rf dist/shared/types",
    "check-types": "tsc --noEmit",
    "start": "nest start",
    "start:dev": "nest start --watch --exec 'node --env-file=.env.development'",
    "start:debug": "nest start --debug --watch --exec 'node --env-file=.env.development'",
    "start:prod": "node --env-file=.env.production dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --config jest.config.ts",
    "test:unit:watch": "jest --config jest.config.ts --watch",
    "test:e2e": "dotenv -e .env.test --quiet -- jest --config jest.config.e2e.ts",
    "test:e2e:watch": "dotenv -e .env.test --quiet -- jest --config jest.config.e2e.ts --watch",
    "migrate:deploy:test": "dotenv -e .env.test -- prisma migrate deploy",
    "test:staged": "jest --findRelatedTests --passWithNoTests",
    "test:ci": "jest --ci --coverage --silent",
    "test:dir": "jest --silent --verbose --",
    "migrate": "dotenv -e .env -- prisma migrate dev",
    "migrate:dev": "dotenv -e .env.development -- prisma migrate dev",
    "migrate:test": "dotenv -e .env.test -- prisma migrate dev",
    "migrate:reset": "dotenv -e .env -- prisma migrate reset",
    "migrate:reset:dev": "dotenv -e .env.development -- prisma migrate reset",
    "migrate:reset:test": "dotenv -e .env.test -- prisma migrate reset",
    "db:seed": "dotenv -e .env.development -- prisma db seed",
    "db:up": "dotenv -e .env.development -- docker-compose -p back_dev -f docker-compose.development.yml up --build -d",
    "db:up:dev": "pnpm run db:up",
    "db:up:test": "dotenv -e .env.test -- docker-compose -p back_test -f docker-compose.test.yml up --build -d --wait",
    "lint": "eslint \"{src,__tests__}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,__tests__}/**/*.ts\"",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.1.1",
    "@nestjs/common": "^11.1.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.12",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-fastify": "^11.1.12",
    "@nestjs/swagger": "^11.2.5",
    "@prisma/adapter-pg": "^7.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "ioredis": "^5.9.2",
    "nestjs-zod": "^5.1.1",
    "pg": "^8.17.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuidv7": "^1.1.0",
    "zod": "^4.3.6",
    "zod-error-map": "0.2.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.12",
    "@prisma/client": "7.3.0",
    "@swc/core": "^1.15.10",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.10",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "eslightning": "^0.3.8",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "fastify": "5.6.2",
    "globals": "^17.1.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "neostandard": "^0.12.2",
    "prisma": "7.3.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
